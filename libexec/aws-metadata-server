#!/usr/bin/env bash

set -eu

readonly CONFIG_FILE="${AWS_METADATA_CONFIG:-/etc/aws-metadata-agent/config}"

if [[ ! -r $CONFIG_FILE ]]; then
  printf 'Configuration file is not readable: %s\n' "$CONFIG_FILE" >&2
  exit 1
fi

# This file is generated by install.sh and writable only by root.
# shellcheck disable=SC1090
source "$CONFIG_FILE"

: "${AWS_METADATA_USER:?Missing AWS_METADATA_USER}"
: "${AWS_METADATA_UID:?Missing AWS_METADATA_UID}"
: "${AWS_METADATA_HOME:?Missing AWS_METADATA_HOME}"
: "${AWS_RUNAS:?Missing AWS_RUNAS}"

if [[ $(id -u) != "$AWS_METADATA_UID" ]]; then
  printf 'Refusing to run credential broker as uid %s; expected uid %s.\n' \
    "$(id -u)" "$AWS_METADATA_UID" >&2
  exit 1
fi

export HOME=$AWS_METADATA_HOME
export USER=$AWS_METADATA_USER
export LOGNAME=$AWS_METADATA_USER

args=(-r serve ec2 --port "${AWS_METADATA_PORT:-18080}")

exec "$AWS_RUNAS" "${args[@]}"
