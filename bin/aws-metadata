#!/usr/bin/env bash

set -u
set -o pipefail

readonly BASE_URL="${AWS_METADATA_URL:-http://169.254.169.254}"
readonly DEFAULT_WAIT="${AWS_METADATA_WAIT_SECONDS:-0}"
readonly AUTH_REQUEST_GRACE_SECONDS=5
readonly VERSION_FILE="${AWS_METADATA_VERSION_FILE:-/usr/local/libexec/aws-metadata-agent/VERSION}"
readonly PACKAGE_ROOT="${AWS_METADATA_PACKAGE_ROOT:-}"
readonly PACKAGE_CLI="${AWS_METADATA_PACKAGE_CLI:-}"

usage() {
  cat <<'EOF'
Usage:
  aws-metadata use PROFILE [--open|--no-open] [--wait SECONDS] [--json]
  aws-metadata profile PROFILE [--open|--no-open] [--wait SECONDS] [--json]
  aws-metadata status [--json]
  aws-metadata open
  aws-metadata refresh
  aws-metadata errors
  aws-metadata logs
  aws-metadata diagnose
  aws-metadata version
  aws-metadata setup [INSTALLER OPTIONS]
  aws-metadata uninstall [--help]
  aws-metadata help

Exit codes for profile:
  0 ready  2 usage  3 unavailable  4 authentication required
  5 authentication timeout  6 unexpected HTTP response
EOF
}

version_command() {
  if (($#)); then
    printf 'Unknown version option: %s\n' "$1" >&2
    return 2
  fi
  if [[ ! -r $VERSION_FILE ]]; then
    printf 'Unable to read the installed version from %s.\n' "$VERSION_FILE" >&2
    return 1
  fi
  command cat "$VERSION_FILE"
}

package_script() {
  local script_name=$1
  local script_path

  if [[ -z $PACKAGE_ROOT ]]; then
    printf '%s\n' \
      'This command is available from the Homebrew-packaged installation.' >&2
    printf 'Source users should run ./%s from a release checkout.\n' \
      "$script_name" >&2
    return 2
  fi
  script_path=$PACKAGE_ROOT/$script_name
  if [[ ! -x $script_path ]]; then
    printf 'The packaged %s was not found at %s.\n' \
      "$script_name" "$script_path" >&2
    return 2
  fi
  printf '%s\n' "$script_path"
}

has_aws_runas_argument() {
  while (($#)); do
    if [[ $1 == --aws-runas ]]; then
      return 0
    fi
    shift
  done
  return 1
}

validate_package_cli() {
  if [[ $PACKAGE_CLI != /* || ! -x $PACKAGE_CLI ]]; then
    printf '%s\n' \
      'The package-managed aws-metadata command path is missing or invalid.' >&2
    return 2
  fi
}

setup_command() {
  local installer bootstrap

  installer=$(package_script install.sh) || return
  if [[ ${1:-} == -h || ${1:-} == --help ]]; then
    exec "$installer" "$@"
  fi
  validate_package_cli || return

  if ! has_aws_runas_argument "$@" && \
     ! command -v aws-runas >/dev/null 2>&1 && \
     [[ ! -x ${HOME:-}/.local/bin/aws-runas ]]; then
    bootstrap=$(package_script bootstrap.sh) || return
    printf '%s\n' \
      'aws-runas was not found; downloading the verified upstream release.'
    "$bootstrap" || return
  fi

  exec "$installer" --package-cli "$PACKAGE_CLI" "$@"
}

uninstall_command() {
  local uninstaller

  uninstaller=$(package_script uninstall.sh) || return
  if [[ ${1:-} == -h || ${1:-} == --help ]]; then
    exec "$uninstaller" "$@"
  fi
  validate_package_cli || return
  exec "$uninstaller" --package-cli "$PACKAGE_CLI" "$@"
}

json_escape() {
  local value=$1
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

print_result() {
  local json=$1
  local state=$2
  local message=$3
  local profile=${4:-}

  if [[ $json == true ]]; then
    printf '{"state":"%s","message":"%s"' \
      "$(json_escape "$state")" "$(json_escape "$message")"
    if [[ -n $profile ]]; then
      printf ',"profile":"%s"' "$(json_escape "$profile")"
    fi
    printf '}\n'
  else
    printf '%s\n' "$message"
  fi
}

broker_log_location() {
  case "$(uname -s)" in
    Darwin)
      printf '%s/Library/Logs/aws-metadata-agent.log' "$HOME"
      ;;
    Linux)
      printf '%s' 'systemd user journal for aws-metadata-agent.service'
      ;;
    *)
      printf '%s' 'unsupported platform'
      ;;
  esac
}

broker_error_summary() {
  local error_text=$1

  case $error_text in
    *'operation error STS: AssumeRoleWithSAML'*'StatusCode: 408'*)
      printf '%s' 'STS AssumeRoleWithSAML returned HTTP 408.'
      ;;
    *'browser closed before authentication completed'*)
      printf '%s' 'Browser authentication closed before completion.'
      ;;
    *'request canceled'*|*'context canceled'*)
      printf '%s' 'The authentication request was canceled.'
      ;;
    *'AccessDenied'*)
      printf '%s' 'AWS denied the upstream credential request.'
      ;;
    *'operation error STS:'*)
      printf '%s' 'The upstream AWS STS exchange failed.'
      ;;
    *'failed to refresh cached credentials'*)
      printf '%s' 'Credential refresh failed.'
      ;;
    *)
      printf '%s' 'The credential broker reported an error; details are redacted.'
      ;;
  esac
}

print_unexpected_profile_response() {
  local json=$1
  local status=$2
  local profile=$3
  local phase=$4
  local output_file=$5
  local message summary log_location

  message="The metadata endpoint at $BASE_URL is reachable, but the credential broker returned HTTP $status $phase $profile."
  summary=$(broker_error_summary "$(<"$output_file")")
  log_location=$(broker_log_location)

  if [[ $json == true ]]; then
    printf '{"state":"error","message":"%s","profile":"%s","broker_error":"%s","diagnostic_command":"aws-metadata errors","broker_log":"%s"}\n' \
      "$(json_escape "$message")" \
      "$(json_escape "$profile")" \
      "$(json_escape "$summary")" \
      "$(json_escape "$log_location")"
  else
    printf '%s\n' "$message"
    printf 'Broker error: %s\n' "$summary"
    printf '%s\n' 'Recent broker errors: aws-metadata errors'
    printf 'Broker log: %s\n' "$log_location"
  fi
}

open_browser() {
  case "$(uname -s)" in
    Darwin)
      command open "$BASE_URL"
      ;;
    Linux)
      if command -v xdg-open >/dev/null 2>&1; then
        command xdg-open "$BASE_URL"
      elif command -v gio >/dev/null 2>&1; then
        command gio open "$BASE_URL"
      else
        printf 'Open %s in a browser.\n' "$BASE_URL" >&2
        return 1
      fi
      ;;
    *)
      printf 'Unsupported operating system. Open %s manually.\n' "$BASE_URL" >&2
      return 1
      ;;
  esac
}

http_request() {
  local method=$1
  local path=$2
  local data=${3:-}
  local output_file=$4
  local request_timeout=${5:-${AWS_METADATA_REQUEST_TIMEOUT:-15}}
  local status curl_exit
  local curl_args=(
    --silent
    --show-error
    --noproxy '*'
    --connect-timeout "${AWS_METADATA_CONNECT_TIMEOUT:-2}"
    --max-time "$request_timeout"
    --output "$output_file"
    --write-out '%{http_code}'
    --request "$method"
  )

  if [[ -n $data ]]; then
    curl_args+=(--header 'Content-Type: application/x-www-form-urlencoded' --data-binary "$data")
  fi

  status=$(command curl "${curl_args[@]}" "${BASE_URL}${path}") || {
    curl_exit=$?
    if [[ $curl_exit -eq 28 ]]; then
      printf 'timeout'
    else
      printf '000'
    fi
    return 0
  }
  printf '%s' "$status"
}

select_profile_once() {
  local profile=$1
  local output_file=$2
  local request_timeout=${3:-${AWS_METADATA_REQUEST_TIMEOUT:-15}}
  http_request POST /profile "$profile" "$output_file" "$request_timeout"
}

is_transient_saml_sts_timeout() {
  local status=$1
  local output_file=$2

  [[ $status == 500 ]] &&
    command grep -Fq 'operation error STS: AssumeRoleWithSAML' "$output_file" &&
    command grep -Fq 'StatusCode: 408' "$output_file"
}

retry_profile_after_transient_timeout() {
  local profile=$1
  local output_file=$2
  local request_timeout=$3
  local request_timeout_is_explicit=$4
  local wait_started=$5
  local wait_seconds=$6
  local now retry_timeout=$request_timeout

  if [[ $request_timeout_is_explicit == false ]]; then
    now=$(date +%s)
    if ((now - wait_started >= wait_seconds)); then
      printf '500'
      return 0
    fi
    retry_timeout=$((wait_seconds - (now - wait_started) + AUTH_REQUEST_GRACE_SECONDS))
  fi

  select_profile_once "$profile" "$output_file" "$retry_timeout"
}

profile_command() (
  local interaction_mode=$1
  shift
  local profile=${1:-}
  local browser=false
  local json=false
  local wait_seconds=$DEFAULT_WAIT
  local status body_file started now request_started request_timeout
  local request_timeout_is_explicit=false
  local transient_retry_used=false

  if [[ $interaction_mode == interactive ]]; then
    browser=true
    wait_seconds=${AWS_METADATA_WAIT_SECONDS:-300}
  fi

  if [[ -z $profile || $profile == --* ]]; then
    printf 'A profile name is required.\n' >&2
    usage >&2
    return 2
  fi
  shift

  while (($#)); do
    case $1 in
      --open) browser=true ;;
      --no-open) browser=false ;;
      --json) json=true ;;
      --wait)
        shift
        if (($# == 0)) || [[ ! $1 =~ ^[0-9]+$ ]]; then
          printf '%s\n' '--wait requires a non-negative integer.' >&2
          return 2
        fi
        wait_seconds=$1
        ;;
      *)
        printf 'Unknown profile option: %s\n' "$1" >&2
        return 2
        ;;
    esac
    shift
  done

  request_timeout=${AWS_METADATA_REQUEST_TIMEOUT:-}
  if [[ -z $request_timeout ]]; then
    request_timeout=15
    if [[ $browser == true ]] && ((wait_seconds > 0)); then
      request_timeout=$((wait_seconds + AUTH_REQUEST_GRACE_SECONDS))
    fi
  else
    request_timeout_is_explicit=true
  fi

  body_file=$(mktemp "${TMPDIR:-/tmp}/aws-metadata.XXXXXX") || return 6
  trap 'rm -f "$body_file"' EXIT

  request_started=$(date +%s)
  status=$(select_profile_once "$profile" "$body_file" "$request_timeout")
  if [[ $browser == true ]] && ((wait_seconds > 0)) &&
    is_transient_saml_sts_timeout "$status" "$body_file"; then
    transient_retry_used=true
    status=$(retry_profile_after_transient_timeout \
      "$profile" "$body_file" "$request_timeout" \
      "$request_timeout_is_explicit" "$request_started" "$wait_seconds")
  fi
  case $status in
    200|204)
      print_result "$json" ready "AWS metadata profile set to $profile." "$profile"
      return 0
      ;;
    timeout)
      if [[ $browser == true ]] && ((wait_seconds > 0)); then
        print_result "$json" timeout \
          "Timed out waiting for authentication for $profile." "$profile"
        return 5
      fi
      print_result "$json" unavailable \
        "AWS metadata service is unavailable at $BASE_URL." "$profile"
      return 3
      ;;
    000)
      print_result "$json" unavailable \
        "AWS metadata service is unavailable at $BASE_URL." "$profile"
      return 3
      ;;
    401) ;;
    *)
      print_unexpected_profile_response \
        "$json" "$status" "$profile" 'while selecting' "$body_file"
      return 6
      ;;
  esac

  if [[ $browser != true ]]; then
    print_result "$json" authentication_required \
      "Authentication is required for $profile. Open $BASE_URL." "$profile"
    return 4
  fi

  open_browser || true
  if ((wait_seconds == 0)); then
    print_result "$json" authentication_required \
      "Authentication is required for $profile; the browser interface was opened." "$profile"
    return 4
  fi

  started=$(date +%s)
  while :; do
    sleep 2
    status=$(select_profile_once "$profile" "$body_file" "$request_timeout")
    if [[ $transient_retry_used == false ]] &&
      is_transient_saml_sts_timeout "$status" "$body_file"; then
      transient_retry_used=true
      status=$(retry_profile_after_transient_timeout \
        "$profile" "$body_file" "$request_timeout" \
        "$request_timeout_is_explicit" "$started" "$wait_seconds")
    fi
    case $status in
      200|204)
        print_result "$json" ready "AWS metadata profile set to $profile." "$profile"
        return 0
        ;;
      timeout)
        print_result "$json" timeout \
          "Timed out waiting for authentication for $profile." "$profile"
        return 5
        ;;
      000)
        print_result "$json" unavailable \
          "AWS metadata service became unavailable at $BASE_URL." "$profile"
        return 3
        ;;
      401) ;;
      *)
        print_unexpected_profile_response \
          "$json" "$status" "$profile" 'while waiting for' "$body_file"
        return 6
        ;;
    esac

    now=$(date +%s)
    if ((now - started >= wait_seconds)); then
      print_result "$json" timeout \
        "Timed out waiting for authentication for $profile." "$profile"
      return 5
    fi
  done
)

status_command() (
  local json=false
  local body_file status body

  if [[ ${1:-} == --json ]]; then
    json=true
    shift
  fi
  if (($#)); then
    printf 'Unknown status option: %s\n' "$1" >&2
    return 2
  fi

  body_file=$(mktemp "${TMPDIR:-/tmp}/aws-metadata.XXXXXX") || return 6
  trap 'rm -f "$body_file"' EXIT
  status=$(http_request GET /profile '' "$body_file")
  body=$(<"$body_file")

  case $status in
    200)
      if [[ $json == true ]]; then
        printf '{"state":"running","endpoint":"%s","profile":%s}\n' \
          "$(json_escape "$BASE_URL")" "${body:-null}"
      else
        printf 'AWS metadata service is running at %s.\n' "$BASE_URL"
        printf 'Active profile: %s\n' "${body:-unknown}"
      fi
      ;;
    500)
      if [[ $body == 'profile not set' ]]; then
        if [[ $json == true ]]; then
          printf '{"state":"running","endpoint":"%s","profile":null}\n' \
            "$(json_escape "$BASE_URL")"
        else
          printf 'AWS metadata service is running at %s.\n' "$BASE_URL"
          printf '%s\n' 'No profile is selected.'
        fi
      else
        print_result "$json" error \
          "AWS metadata service returned HTTP $status."
        return 6
      fi
      ;;
    000|timeout)
      print_result "$json" unavailable \
        "AWS metadata service is unavailable at $BASE_URL."
      return 3
      ;;
    *)
      print_result "$json" error \
        "AWS metadata service returned HTTP $status."
      return 6
      ;;
  esac
)

logs_command() {
  case "$(uname -s)" in
    Darwin)
      command tail -n 100 -f "$HOME/Library/Logs/aws-metadata-agent.log"
      ;;
    Linux)
      command journalctl --user-unit aws-metadata-agent.service --lines 100 --follow
      ;;
    *)
      printf 'Unsupported operating system.\n' >&2
      return 2
      ;;
  esac
}

recent_broker_error_lines() {
  case "$(uname -s)" in
    Darwin)
      command tail -n 200 "$(broker_log_location)" |
        command grep -F 'handleAuthError:' |
        command tail -n 10
      ;;
    Linux)
      command journalctl --user-unit aws-metadata-agent.service \
        --lines 200 --no-pager -o cat 2>/dev/null |
        command grep -F 'handleAuthError:' |
        command tail -n 10
      ;;
    *)
      return 2
      ;;
  esac
}

errors_command() {
  local line count=0 log_location

  if (($#)); then
    printf 'Unknown errors option: %s\n' "$1" >&2
    return 2
  fi

  log_location=$(broker_log_location)
  case "$(uname -s)" in
    Darwin)
      if [[ ! -r $log_location ]]; then
        printf 'Broker log is not readable at %s.\n' "$log_location" >&2
        return 1
      fi
      ;;
    Linux)
      if ! command -v journalctl >/dev/null 2>&1; then
        printf '%s\n' 'journalctl is required to read the broker log.' >&2
        return 1
      fi
      ;;
    *)
      printf '%s\n' 'Unsupported operating system.' >&2
      return 2
      ;;
  esac

  while IFS= read -r line; do
    printf -- '- %s\n' "$(broker_error_summary "$line")"
    count=$((count + 1))
  done < <(recent_broker_error_lines)

  if ((count == 0)); then
    printf '%s\n' \
      'No broker authentication errors were found in the last 200 log lines.'
  fi
  printf 'Broker log: %s\n' "$log_location"
}

diagnose_command() {
  local status=0

  printf 'Platform: %s\n' "$(uname -s)"
  printf 'Configured endpoint: %s\n' "$BASE_URL"
  if command -v aws-runas >/dev/null 2>&1; then
    printf 'aws-runas: %s\n' "$(command -v aws-runas)"
    aws-runas --version 2>&1 | sed 's/^/  /'
  else
    printf '%s\n' 'aws-runas: not found in PATH'
    status=1
  fi

  if status_command >/dev/null 2>&1; then
    printf '%s\n' 'Metadata HTTP API: reachable'
  else
    printf '%s\n' 'Metadata HTTP API: unreachable'
    status=1
  fi
  printf 'Broker log: %s\n' "$(broker_log_location)"
  printf '%s\n' 'Recent broker errors: aws-metadata errors'

  case $(uname -s) in
    Darwin)
      if /sbin/ifconfig lo0 inet 2>/dev/null | grep -Fq '169.254.169.254'; then
        printf '%s\n' 'Link-local address: present on lo0'
      else
        printf '%s\n' 'Link-local address: missing from lo0'
        status=1
      fi
      if launchctl print \
        "gui/$(id -u)/com.github.so1omon563.aws-metadata-agent.broker" \
        >/dev/null 2>&1; then
        printf '%s\n' 'User broker service: loaded'
      else
          printf '%s\n' 'User broker service: not loaded'
          status=1
      fi
      ;;
    Linux)
      if command -v ip >/dev/null 2>&1 && \
         ip -4 address show dev lo 2>/dev/null | grep -Fq '169.254.169.254/32'; then
        printf '%s\n' 'Link-local address: present on lo'
      else
        printf '%s\n' 'Link-local address: missing from lo'
        status=1
      fi
      if systemctl --user is-active aws-metadata-agent.service >/dev/null 2>&1; then
        printf '%s\n' 'User broker service: active'
      else
          printf '%s\n' 'User broker service: inactive'
          status=1
      fi
      ;;
  esac
  return "$status"
}

main() {
  local command_name=${1:-help}
  if (($#)); then shift; fi

  case $command_name in
    use) profile_command interactive "$@" ;;
    profile) profile_command automation "$@" ;;
    status) status_command "$@" ;;
    open|refresh) open_browser ;;
    errors) errors_command "$@" ;;
    logs) logs_command "$@" ;;
    diagnose|doctor) diagnose_command "$@" ;;
    version|--version) version_command "$@" ;;
    setup) setup_command "$@" ;;
    uninstall) uninstall_command "$@" ;;
    help|-h|--help) usage ;;
    *)
      printf 'Unknown command: %s\n' "$command_name" >&2
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
